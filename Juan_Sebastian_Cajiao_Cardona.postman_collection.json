    {
      "name": "05 - Eliminar producto",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "pm.test('Codigo de estado es 200', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Respuesta contiene mensaje 'Producto eliminado'\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('mensaje');\r",
              "    pm.expect(jsonData.mensaje).to.eql('Producto eliminado');\r",
              "});\r",
              "\r",
              "pm.test('Actualizar CANTIDAD_PRODUCTOS al eliminar', function () {\r",
              "    let cantidad = Number(pm.collectionVariables.get('CANTIDAD_PRODUCTOS') || 0);\r",
              "    pm.collectionVariables.set('CANTIDAD_PRODUCTOS', Math.max(cantidad - 1, 0));\r",
              "});\r"
            ]
          }
        }
      ],
      "request": {
