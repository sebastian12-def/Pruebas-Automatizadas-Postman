    {
      "name": "04 - Actualizar producto",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "pm.test('Codigo de estado es 200', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Respuesta contiene atributo 'producto' de tipo object\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('producto');\r",
              "    pm.expect(jsonData.producto).to.be.an('object');\r",
              "});\r",
              "\r",
              "pm.test('Producto actualizado conserva el _id y cambia el nombre', function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.producto._id).to.eql(pm.collectionVariables.get('ID_PRODUCTO'));\r",
              "    pm.expect(jsonData.producto.nombre).to.eql('Teclado c63 MAX V1');\r",
              "});\r"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
