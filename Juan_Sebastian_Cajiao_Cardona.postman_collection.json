  "item": [
    {
      "name": "01 - Crear producto",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "const codigo = Number(pm.variables.replaceIn('{{$timestamp}}')) + pm.info.iteration;\r",
              "pm.collectionVariables.set('CODIGO_PRODUCTO', codigo);\r"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "pm.test('Codigo de estado es 201', function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test('Respuesta contiene precio de tipo number', function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.precio).to.be.a('number');\r",
              "});\r",
              "\r",
              "pm.test('Respuesta contiene _id y codigo enviado', function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('_id');\r",
              "    pm.expect(jsonData.codigo).to.eql(Number(pm.collectionVariables.get('CODIGO_PRODUCTO')));\r",
              "});\r",
              "\r",
              "pm.test('Tiempo de respuesta menor a 5000 milisegundos', function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});\r",
              "\r",
              "pm.test('Guardar ID del producto creado', function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.collectionVariables.set('ID_PRODUCTO', jsonData._id);\r",
              "});\r"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}",
          "host": [
            "{{base_url}}"
          ],
          "path": []
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"codigo\": {{CODIGO_PRODUCTO}},\n  \"nombre\": \"Teclado c63 MAX\",\n  \"precio\": 15000,\n  \"categoria\": \"Electrodomestico\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": []
    },
    {
      "name": "02 - Obtener productos",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "pm.test('Codigo de estado es 200', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('Respuesta es un array y actualiza CANTIDAD_PRODUCTOS', function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an('array');\r",
              "    pm.collectionVariables.set('CANTIDAD_PRODUCTOS', jsonData.length);\r",
              "});\r",
              "\r",
              "pm.test('Los productos contienen el campo codigo', function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    if (jsonData.length > 0) {\r",
              "        pm.expect(jsonData[0]).to.have.property('codigo');\r",
              "        pm.expect(jsonData[0].codigo).to.be.a('number');\r",
              "    }\r",
              "});\r"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}",
          "host": [
            "{{base_url}}"
          ],
          "path": []
        }
      },
      "response": []
    },
    {
      "name": "03 - Obtener producto por ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "pm.test('Codigo de estado es 200', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('Respuesta contiene el _id correcto', function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    const idEsperado = pm.collectionVariables.get('ID_PRODUCTO');\r",
              "    pm.expect(jsonData).to.have.property('_id');\r",
              "    pm.expect(jsonData._id).to.eql(idEsperado);\r",
              "});\r",
              "\r",
              "pm.test('Respuesta contiene campo codigo', function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('codigo');\r",
              "});\r"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/{{ID_PRODUCTO}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "{{ID_PRODUCTO}}"
          ]
        }
      },
      "response": []
